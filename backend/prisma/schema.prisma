generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                Int                   @id @default(autoincrement())
  email             String                @unique
  name              String?
  password          String
  role              Role                  @default(user)
  approved          Boolean               @default(false)
  uploadedDocuments CustomerDocument[]    @relation("DocumentUploader")
  mentionsMade      CustomerNoteMention[] @relation("MentionedBy")
  mentionsReceived  CustomerNoteMention[] @relation("MentionedUser")
  customers         Customer[]            @relation("CustomerOwner")
  exchanges         Exchange[]            @relation("ExchangeWriter")

  @@map("users")
}

model Customer {
  id           Int                   @id @default(autoincrement())
  name         String?
  field        String?
  from_source  String?
  price        Decimal?              @db.Decimal(15, 0)
  status       String?
  classified   Classified?
  email        String?               @unique @default("NULL")
  phone_number String?               @unique
  address      String?
  link_url     String?
  appointment  DateTime?
  note         String?
  owner_id     Int?
  created_at   DateTime              @default(now())
  updated_at   DateTime              @updatedAt
  company_id   Int?
  documents    CustomerDocument[]
  mentions     CustomerNoteMention[]
  company      Company?              @relation(fields: [company_id], references: [id])
  owner        User?                 @relation("CustomerOwner", fields: [owner_id], references: [id])
  exchanges    Exchange[]

  @@map("customers")
}

model CustomerDocument {
  id          Int      @id @default(autoincrement())
  customer_id Int
  file_name   String?
  file_url    String?
  uploaded_by Int
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  customer    Customer @relation(fields: [customer_id], references: [id])
  uploader    User     @relation("DocumentUploader", fields: [uploaded_by], references: [id])

  @@map("customer_documents")
}

model Exchange {
  id          Int      @id @default(autoincrement())
  customer_id Int
  writer_id   Int
  content     String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  customer    Customer @relation(fields: [customer_id], references: [id])
  writer      User     @relation("ExchangeWriter", fields: [writer_id], references: [id])

  @@map("exchanges")
}

model CustomerNoteMention {
  id                Int      @id @default(autoincrement())
  customer_id       Int
  mentioned_user_id Int
  mentioned_by      Int
  created_at        DateTime @default(now())
  customer          Customer @relation(fields: [customer_id], references: [id])
  mentionedByUser   User     @relation("MentionedBy", fields: [mentioned_by], references: [id])
  mentionedUser     User     @relation("MentionedUser", fields: [mentioned_user_id], references: [id])

  @@map("customer_note_mentions")
}

model Company {
  id              Int           @id @default(autoincrement())
  name            String
  tax_code        String?       @unique
  email           String?       @unique
  phone           String?
  website         String?
  facebook        String?
  linkedin        String?
  zalo            String?
  address         String?
  location        String?
  field           String?
  status          CompanyStatus @default(potential)
  note            String?
  bank_name       String?
  bank_account_no String?
  bank_branch     String?
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
  customers       Customer[]

  @@map("companies")
}

enum Role {
  admin
  user
}

enum Classified {
  VIP
  Normal
  Lead
}

enum CompanyStatus {
  active
  inactive
  potential
}
